{
  "metadata": {
    "name": "pai-example"
  },
  "dockerAuth": "base64-encoded-registry-auth",
  "cloud": {
    "computing": {
      "instance_type": "ecs.gn6i-c8g1.2xlarge.limit",
      "instance_count": 1
    }
  },
  "autoscaler": {
    "min": 0,
    "max": 1
  },
  "containers": [
    {
      "image": "registry-internal-vpc.cn-hangzhou.aliyuncs.com/your-private-namespace/pai-example:latest",
      "port": 8000,
      "env": [
        {
          "name": "PORT",
          "value": "8000"
        },
        {
          "name": "PYTHONPATH",
          "value": "/app"
        },
        {
          "name": "MODEL_URI",
          "value": "oss://your-bucket/models/your-model.tar.gz"
        },
        {
          "name": "OSS_ENDPOINT",
          "value": "oss-cn-hangzhou-internal.aliyuncs.com"
        },
        {
          "name": "APP_START_CMD",
          "value": "uvicorn service:app --host 0.0.0.0 --port ${PORT:-8000}"
        }
      ]
    }
  ],
  "probe": {
    "readiness": {
      "http_get": {
        "path": "/healthz",
        "port": 8000
      }
    }
  }
}
